{
  "name": "studio",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "sanity"
  ],
  "license": "UNLICENSED",
  "main": "package.json",
  "scripts": {
    "build": "sanity build",
    "deploy": "sanity deploy",
    "predev": "npm run sanity:typegen",
    "dev": "sanity dev",
    "sanity:typegen": "sanity schema extract --enforce-required-fields --path ../sanity.schema.json && sanity typegen generate",
    "start": "sanity start",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sanity/assist": "^6.0.7",
    "@sanity/icons": "^3.7.4",
    "@sanity/vision": "^5.28.0",
    "date-fns": "^4.4.0",
    "pluralize-esm": "^9.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rxjs": "^7.8.2",
    "sanity": "^5.28.0",
    "sanity-plugin-asset-source-unsplash": "^7.0.7",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.16",
    "typescript": "^5.9.3"
  }
}
